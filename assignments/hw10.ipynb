    "import re\n",
    "from collections import Counter\n",
    "\n",
    "url = re.compile(r\"https?://\\S+\")\n",
    "html = re.compile(r\"<[^>]+>\")\n",
    "email = re.compile(r\"[\\w\\.-]+@[\\w\\.-]+\\.\\w+\")\n",
    "phone_number = re.compile(r\"\\d{2,4}-\\d{3,4}-\\d{4}\")\n",
    "mention = re.compile(r\"@\\w+\")\n",
    "hashtag = re.compile(r\"#\\w+\")\n",
    "korean_pattern_recompile = re.compile(r\"[ㄱ-ㅎㅏ-ㅣ]+\")\n",
    "space = re.compile(r\"\\s+\")\n",
    "\n",
    "def clean_post(post: str) -> str:\n",
    "    post = url.sub(\" \", post)\n",
    "    post = html.sub(\"\", post)\n",
    "    post = email.sub(\"[이메일]\", post)\n",
    "    post = phone_number.sub(\"[전화]\", post)\n",
    "    post = mention.sub(\" \", post)\n",
    "    post = hashtag.sub(\" \", post)\n",
    "    post = korean_pattern_recompile.sub(\"\", post)\n",
    "    post = space.sub(\" \", post).strip()\n",
    "    return post\n",
    "\n",
    "def extract_hashtags(post: str) -> list[str]:\n",
    "    tag = re.findall(r\"#(\\w+)\", post)\n",
    "    return tags\n",
    "\n",
    "def analyze_posts(posts: list[str]) -> dict:\n",
    "    posts_lens = len(posts)\n",
    "    cleaned_lengths = []\n",
    "    hashtag_list = []\n",
    "    count = 0\n",
    "\n",
    "    for post in posts:\n",
    "        hashtag_list.extend(extract_hashtags(post))\n",
    "\n",
    "        p = url.sub(\" \", post)\n",
    "        p = html.sub(\"\", p)\n",
    "\n",
    "        p, email_count = email.subn(\"[이메일]\", p)\n",
    "        p, phone_count = phone_number.subn(\"[전화]\", p)\n",
    "        count += (email_count + phone_count)\n",
    "\n",
    "        p = mention.sub(\" \", p)\n",
    "        p = hashtag.sub(\" \", p)\n",
    "        p = korean_pattern_recompile.sub(\"\", p)\n",
    "        cleaned_post_str = space.sub(\" \", p).strip()\n",
    "\n",
    "        cleaned_lengths.append(len(cleaned_post_str))\n",
    "\n",
    "    avg_length = round(sum(cleaned_lengths) / posts_lens, 2) if posts_lens > 0 else 0.0\n",
    "    hashtag_count = Counter(hashtag_list)\n",
    "    sorted_hashtag_count = dict(hashtag_count.most_comon())\n",
    "    \n",
    "    return {\n",
    "        \"posts_n\": posts_lens,\n",
    "        \"avg_length_after_clean\": avg_length,\n",
    "        \"hashtag_counts\": sorted_hashtag_count,\n",
    "        \"masked_count\": count\n",
    "    }\n",
    "\n",
    "posts: list[str] = [\n",
    "    \"오늘 #파이썬 수업 진짜 재밌었음!! @prof_kim @hong 감사 ㅎㅎ\",\n",
    "    \"자료: https://etl.snu.ac.kr/lec17\",\n",
    "    \"@lee @park 팀플 어디서 모이지ㅠㅠㅠㅠㅠㅠ #DCCP2026 #팀플 카톡 ㄱㄱ\",\n",
    "    \"<b>중요</b>: 다음 시험 범위는 1-15강.\",\n",
    "    \"문의는 mam3b@snu.ac.kr (010-1234-5678)로!\",\n",
    "    \" 여러 공백과\\n\\n\\n줄바꿈이 많은 텍스트\",\n",
    "    \"ㅋㅋㅋ #파이썬 진짜 좋다 #추천 https://snu.ac.kr\"\n",
    "]"
   ]
